generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskPriority {
  NONE
  LOW
  MEDIUM
  HIGH
  URGENT
}

model User {
  id                   String            @id @default(cuid())
  email                String            @unique
  passwordHash         String
  name                 String
  avatarUrl            String?
  bio                  String?
  preferredLocale      String            @default("pt-BR")
  preferredTheme       String            @default("system")
  passwordResetToken   String?           @unique
  passwordResetExpires DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  refreshTokens        RefreshToken[]
  ownedProjects        Project[]         @relation("ProjectOwner")
  projectFavorites     ProjectFavorite[]
  createdTasks         Task[]            @relation("TaskCreator")
  assignedTasks        Task[]            @relation("TaskAssignee")
  comments             Comment[]
  attachments          Attachment[]

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  @@index([userId])
  @@map("refresh_tokens")
}

model Project {
  id          String            @id @default(cuid())
  name        String
  description String?
  key         String
  color       String            @default("#1f6feb")
  ownerId     String
  owner       User              @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  archivedAt  DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  favorites   ProjectFavorite[]
  board       Board?
  labels      Label[]

  @@unique([ownerId, key])
  @@index([ownerId])
  @@index([name])
  @@map("projects")
}

model ProjectFavorite {
  userId    String
  projectId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([userId, projectId])
  @@index([projectId])
  @@map("project_favorites")
}

model Board {
  id        String   @id @default(cuid())
  name      String   @default("Main")
  projectId String   @unique
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  columns   Column[]

  @@map("boards")
}

model Column {
  id        String   @id @default(cuid())
  boardId   String
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  name      String
  key       String
  position  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tasks     Task[]

  @@unique([boardId, key])
  @@index([boardId, position])
  @@map("columns")
}

model Label {
  id        String      @id @default(cuid())
  projectId String
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  color     String      @default("#8b95a5")
  createdAt DateTime    @default(now())
  tasks     TaskLabel[]

  @@unique([projectId, name])
  @@index([projectId])
  @@map("labels")
}

model Task {
  id               String          @id @default(cuid())
  columnId         String
  column           Column          @relation(fields: [columnId], references: [id], onDelete: Cascade)
  title            String
  description      String?
  position         Int
  priority         TaskPriority    @default(NONE)
  dueDate          DateTime?
  estimatedMinutes Int?
  spentMinutes     Int             @default(0)
  assigneeId       String?
  assignee         User?           @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdById      String?
  createdBy        User?           @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  labels           TaskLabel[]
  checklist        ChecklistItem[]
  comments         Comment[]
  attachments      Attachment[]

  @@index([columnId, position])
  @@index([assigneeId])
  @@map("tasks")
}

model TaskLabel {
  taskId  String
  labelId String
  task    Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label   Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
  @@index([labelId])
  @@map("task_labels")
}

model ChecklistItem {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title     String
  done      Boolean  @default(false)
  position  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId, position])
  @@map("checklist_items")
}

model Comment {
  id          String       @id @default(cuid())
  taskId      String
  task        Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId    String
  author      User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body        String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  attachments Attachment[]

  @@index([taskId, createdAt])
  @@map("comments")
}

model Attachment {
  id           String    @id @default(cuid())
  taskId       String?
  task         Task?     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  commentId    String?
  comment      Comment?  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  filename     String
  originalName String
  mimeType     String
  size         Int
  storagePath  String
  uploadedById String
  uploadedBy   User      @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())

  @@index([taskId])
  @@index([commentId])
  @@map("attachments")
}
