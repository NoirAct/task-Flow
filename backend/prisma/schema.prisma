generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String            @id @default(cuid())
  email                String            @unique
  passwordHash         String
  name                 String
  avatarUrl            String?
  bio                  String?
  preferredLocale      String            @default("pt-BR")
  preferredTheme       String            @default("system")
  passwordResetToken   String?           @unique
  passwordResetExpires DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  refreshTokens        RefreshToken[]
  ownedProjects        Project[]         @relation("ProjectOwner")
  projectFavorites     ProjectFavorite[]
  createdTasks         Task[]            @relation("TaskCreator")

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  @@index([userId])
  @@map("refresh_tokens")
}

model Project {
  id          String            @id @default(cuid())
  name        String
  description String?
  key         String
  color       String            @default("#1f6feb")
  ownerId     String
  owner       User              @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  archivedAt  DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  favorites   ProjectFavorite[]
  board       Board?

  @@unique([ownerId, key])
  @@index([ownerId])
  @@index([name])
  @@map("projects")
}

model ProjectFavorite {
  userId    String
  projectId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([userId, projectId])
  @@index([projectId])
  @@map("project_favorites")
}

model Board {
  id        String   @id @default(cuid())
  name      String   @default("Main")
  projectId String   @unique
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  columns   Column[]

  @@map("boards")
}

model Column {
  id        String   @id @default(cuid())
  boardId   String
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  name      String
  key       String
  position  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tasks     Task[]

  @@unique([boardId, key])
  @@index([boardId, position])
  @@map("columns")
}

model Task {
  id          String   @id @default(cuid())
  columnId    String
  column      Column   @relation(fields: [columnId], references: [id], onDelete: Cascade)
  title       String
  description String?
  position    Int
  createdById String?
  createdBy   User?    @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([columnId, position])
  @@map("tasks")
}
